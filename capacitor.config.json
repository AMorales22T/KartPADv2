{
  "appId": "com.kardpad.app",
  "appName": "KardPad",
  "webDir": "static",
  "server": {
    "allowNavigation": ["*"],
    "iosScheme": "http",
    "androidScheme": "http",
    "cleartext": true
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#06060e",
    "preferredContentMode": "mobile",
    "limitsNavigationsToAppBoundDomains": false,
    "allowsLinkPreview": false
  },
  "plugins": {
    "ScreenOrientation": {
      "allowRotate": false
    }
  }
}
